<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="SpdWindowBrush" Color="#F4F5F7"/>
    <SolidColorBrush x:Key="SpdPanelBrush" Color="#FDFDFE"/>
    <SolidColorBrush x:Key="SpdTextBrush" Color="#111827"/>
    <SolidColorBrush x:Key="SpdMutedBrush" Color="#667085"/>
    <SolidColorBrush x:Key="SpdAccentBrush" Color="#0A84FF"/>
    <SolidColorBrush x:Key="SpdSeparatorBrush" Color="#D0D5DD"/>

    <Style x:Key="SpdPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource SpdAccentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SpdAccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SpdSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource SpdTextBrush}"/>
        <Setter Property="Background" Value="#EEF1F6"/>
        <Setter Property="BorderBrush" Value="{StaticResource SpdSeparatorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
<Page
    x:Class="SmartPerformanceDoctor.App.Views.ModulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Spacing="18">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="TitleText" Text="모듈" Style="{StaticResource MacPageTitleStyle}"/>
                    <TextBlock x:Name="SubtitleText" Foreground="{StaticResource SpdMacSecondaryTextBrush}" FontSize="15" TextWrapping="Wrap"/>
                </StackPanel>
                <Button x:Name="RunButton" Grid.Column="1" Content="실행" Style="{StaticResource MacToolbarButtonStyle}" Click="RunModule" VerticalAlignment="Center"/>
            </Grid>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="전용 파이프라인" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <ItemsControl x:Name="PipelineList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="0,0,0,6" Style="{StaticResource MacListItemSubtitleStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="실행 상태" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <ProgressBar x:Name="Progress" Value="0" Maximum="100"/>
                    <TextBlock x:Name="StatusText" Text="대기 중"/>
                    <TextBlock x:Name="LatestMessageText" Text="작업을 시작하면 진단 흐름이 표시됩니다." TextWrapping="Wrap" Style="{StaticResource MacInlineStatusTextStyle}"/>
                    <ListView x:Name="EventList" SelectionMode="None" MaxHeight="220"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="인텔리전스 결과" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <TextBlock x:Name="IntelligenceText" Text="아직 결과가 없습니다." TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
<Page
    x:Class="SmartPerformanceDoctor.App.Views.CareCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" MaxWidth="1120" Spacing="20">
            <StackPanel Spacing="5">
                <TextBlock Text="PC 최적화" Style="{StaticResource MacPageTitleStyle}"/>
                <TextBlock Text="검사부터 결과 검토, 정리와 복구까지 한 흐름으로 진행합니다."
                           Style="{StaticResource MacInlineStatusTextStyle}"/>
            </StackPanel>

            <Border Style="{StaticResource PremiumHeroCardStyle}" Background="#173E78" BorderBrush="#224F8C">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">
                    <StackPanel Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="권장 점검" Foreground="#A9CBFF" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="PC 상태를 한 번에 확인하세요" Foreground="White" FontSize="27" FontWeight="SemiBold"/>
                        <TextBlock Text="개인 파일을 제외하고 안전한 항목부터 확인합니다 · 예상 약 2분"
                                   Foreground="#D5E5FA" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                            <Button Content="빠른 점검 시작" Style="{StaticResource PremiumPrimaryButtonStyle}" Click="StartQuickCare"/>
                            <Button Content="점검 범위 선택" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenUnifiedCare"/>
                        </StackPanel>
                    </StackPanel>
                    <Grid Grid.Column="1" Width="142" Height="142">
                        <Ellipse Stroke="#40FFFFFF" StrokeThickness="11"/>
                        <Ellipse Stroke="#5ADAA7" StrokeThickness="11" StrokeDashArray="4,1.2"/>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="—" Foreground="White" FontSize="38" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="점검 전" Foreground="#C8DCF7" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Grid.Column="0" Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="7">
                        <TextBlock Text="저장 공간" Foreground="{StaticResource SpdMutedTextBrush}"/>
                        <TextBlock Text="점검 전" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="검사 후 정리 가능 용량 표시" Style="{StaticResource MacListItemSubtitleStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="7">
                        <TextBlock Text="시작 속도" Foreground="{StaticResource SpdMutedTextBrush}"/>
                        <TextBlock Text="점검 전" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="검사 후 시작 앱 상태 표시" Style="{StaticResource MacListItemSubtitleStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="7">
                        <TextBlock Text="시스템 상태" Foreground="{StaticResource SpdMutedTextBrush}"/>
                        <TextBlock Text="점검 전" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource SpdMacAccentBrush}"/>
                        <TextBlock Text="진단 후 시스템 상태 표시" Style="{StaticResource MacListItemSubtitleStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="필요한 작업을 선택하세요" Style="{StaticResource MacSectionHeaderStyle}" Margin="0,8,0,0"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="14" RowDefinitions="Auto,Auto" RowSpacing="14">
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource MacWindowPanelStyle}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Spacing="5">
                            <TextBlock Text="시스템 케어" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="캐시, 임시 파일, 개인정보 흔적, 바로가기와 안전한 레지스트리 잔여물을 검사합니다."
                                       Style="{StaticResource MacListItemSubtitleStyle}" TextWrapping="Wrap"/>
                            <TextBlock Text="결과를 확인한 뒤 항목별로 선택 가능" Foreground="{StaticResource SpdMacGreenBrush}" FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="열기" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenSystemCare" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource MacWindowPanelStyle}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Spacing="5">
                            <TextBlock Text="전체 시스템 점검" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="저장 장치, 서비스, WMI, 안정성 이벤트와 재부팅 대기 상태를 함께 분석합니다."
                                       Style="{StaticResource MacListItemSubtitleStyle}" TextWrapping="Wrap"/>
                            <TextBlock Text="진단만 또는 안전 복구 선택" Foreground="{StaticResource SpdMacAccentBrush}" FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="열기" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenFullCare" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource MacWindowPanelStyle}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Spacing="5">
                            <TextBlock Text="드라이버 진단" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="문제 장치, 드라이버 저장소와 Kernel-PnP 오류를 상관 분석합니다."
                                       Style="{StaticResource MacListItemSubtitleStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="진단" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenDriverCare" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MacWindowPanelStyle}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Spacing="5">
                            <TextBlock Text="오디오 진단" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="오디오 장치, 서비스와 최근 오류를 확인하고 안전한 복구 순서를 제안합니다."
                                       Style="{StaticResource MacListItemSubtitleStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="진단" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenAudioCare" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>

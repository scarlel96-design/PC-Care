<Page
    x:Class="SmartPerformanceDoctor.App.Views.FeatureManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <TextBlock Text="기능 관리" Style="{StaticResource MacPageTitleStyle}"/>
            <TextBlock Text="설치된 기능만 메뉴에 표시됩니다. 설치 관리자를 다시 실행하면 기능을 추가·제거할 수 있습니다."
                       Style="{StaticResource MacInlineStatusTextStyle}"/>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="설치 상태" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <TextBlock x:Name="SummaryText" TextWrapping="Wrap" Style="{StaticResource MacInlineStatusTextStyle}"/>
                    <ListView x:Name="FeatureList" MinHeight="320" SelectionMode="None"/>
                    <Button Content="설치 관리자 열기" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenInstaller"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
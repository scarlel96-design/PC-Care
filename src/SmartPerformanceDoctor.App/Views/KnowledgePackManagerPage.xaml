<Page
    x:Class="SmartPerformanceDoctor.App.Views.KnowledgePackManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="규칙 데이터" Style="{StaticResource MacPageTitleStyle}"/>
                <Button Grid.Column="1" Content="검증" Style="{StaticResource MacToolbarButtonStyle}" Click="Verify"/>
            </Grid>
            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="StatusText" Style="{StaticResource MacEmphasisValueStyle}"/>
                    <TextBlock x:Name="RulesChecksumText" Style="{StaticResource MacInlineStatusTextStyle}"/>
                    <TextBlock x:Name="ProtocolsChecksumText" Style="{StaticResource MacInlineStatusTextStyle}"/>
                    <TextBlock Text="데이터가 맞지 않으면 이전 버전을 그대로 씁니다."
                               Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
<Page
    x:Class="SmartPerformanceDoctor.App.Views.SecurityCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalContentAlignment="Stretch">
        <StackPanel Padding="{StaticResource PccPagePadding}" MaxWidth="1060" HorizontalAlignment="Stretch" Spacing="20">
            <Grid x:Name="SecurityHeaderGrid" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="10">
                <StackPanel Spacing="5">
                    <TextBlock Text="보안" Style="{StaticResource MacPageTitleStyle}"/>
                    <TextBlock Text="암호화 보관과 복구하기 어려운 삭제를 같은 안전 원칙으로 관리합니다."
                               Style="{StaticResource MacInlineStatusTextStyle}" TextWrapping="Wrap"/>
                </StackPanel>
                <Border x:Name="SecurityStatusBadge" Grid.Column="1" Padding="12,7" CornerRadius="16"
                        Background="{StaticResource PccSuccessSoftBrush}" VerticalAlignment="Center">
                    <TextBlock Text="● 보호 도구 준비됨" Foreground="{StaticResource PccSuccessBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <Grid x:Name="SecurityCardGrid" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="18" RowSpacing="18" SizeChanged="SecurityCardGridSizeChanged">
                <Border x:Name="VaultCard" Grid.Column="0" Style="{StaticResource PccCardStyle}" MinHeight="330">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <Border Width="58" Height="58" CornerRadius="17" Background="{StaticResource PccAccentSoftBrush}">
                                <FontIcon Glyph="&#xE72E;" FontFamily="Segoe Fluent Icons" FontSize="25"
                                          Foreground="{StaticResource PccAccentBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Padding="10,5" CornerRadius="14"
                                    Background="{StaticResource PccSuccessSoftBrush}" VerticalAlignment="Top">
                                <TextBlock Text="암호화 보호" Foreground="{StaticResource PccSuccessBrush}" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="보안 금고" FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource PccTextBrush}"/>
                        <TextBlock Text="중요한 파일과 폴더를 암호화해 보관하고, 잠근 뒤에는 다른 프로그램이 내용을 읽지 못하도록 보호합니다."
                                   Foreground="{StaticResource PccTextMutedBrush}" TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,8,0,4">
                            <Border Background="{StaticResource PccSurfaceMutedBrush}" CornerRadius="12" Padding="10">
                                <StackPanel Spacing="3"><TextBlock Text="암호화" FontWeight="SemiBold" Foreground="{StaticResource PccTextBrush}"/><TextBlock Text="파일 보호" FontSize="11" Foreground="{StaticResource PccTextMutedBrush}"/></StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{StaticResource PccSurfaceMutedBrush}" CornerRadius="12" Padding="10">
                                <StackPanel Spacing="3"><TextBlock Text="무결성" FontWeight="SemiBold" Foreground="{StaticResource PccTextBrush}"/><TextBlock Text="변조 확인" FontSize="11" Foreground="{StaticResource PccTextMutedBrush}"/></StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{StaticResource PccSurfaceMutedBrush}" CornerRadius="12" Padding="10">
                                <StackPanel Spacing="3"><TextBlock Text="자동 잠금" FontWeight="SemiBold" Foreground="{StaticResource PccTextBrush}"/><TextBlock Text="노출 방지" FontSize="11" Foreground="{StaticResource PccTextMutedBrush}"/></StackPanel>
                            </Border>
                        </Grid>
                        <Button Content="금고 열기" Style="{StaticResource PccPrimaryButtonStyle}" Click="OpenVault" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border x:Name="DeleteCard" Grid.Column="1" Style="{StaticResource PccCardStyle}" MinHeight="330">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <Border Width="58" Height="58" CornerRadius="17" Background="{StaticResource PccDangerSoftBrush}">
                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="25"
                                          Foreground="{StaticResource PccDangerBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Padding="10,5" CornerRadius="14"
                                    Background="{StaticResource PccCautionSoftBrush}" VerticalAlignment="Top">
                                <TextBlock Text="확인 후 실행" Foreground="{StaticResource PccCautionBrush}" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="보안 삭제" FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource PccTextBrush}"/>
                        <TextBlock Text="선택한 파일을 복구하기 어렵도록 삭제합니다. 실행 전 대상, 저장 장치 특성, 삭제 방식을 다시 확인합니다."
                                   Foreground="{StaticResource PccTextMutedBrush}" TextWrapping="Wrap"/>
                        <Border Padding="14" CornerRadius="12" Background="{StaticResource PccDangerSoftBrush}" Margin="0,8,0,4">
                            <StackPanel Spacing="4">
                                <TextBlock Text="삭제 후 원상 복구할 수 없습니다" Foreground="{StaticResource PccDangerBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="미리보기와 확인 문구를 통과한 대상만 처리합니다."
                                           Foreground="#A85F62" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Button Content="삭제할 파일 선택" Style="{StaticResource PccDangerButtonStyle}" Click="OpenSecureDelete" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Expander Header="고급 보안 및 복구 도구" HorizontalAlignment="Stretch">
                <Grid x:Name="SecurityToolGrid" ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8" Padding="0,12,0,0">
                    <Button x:Name="VaultIntegrityButton" Content="금고 무결성 검사" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenVault"/>
                    <Button x:Name="ProtectionStatusButton" Grid.Column="1" Content="프로그램 보호 상태" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenProtection"/>
                    <Button x:Name="AdvancedRecoveryButton" Grid.Column="2" Content="고급 복구 도구" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenAdvanced"/>
                </Grid>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Page>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- v34 macOS-like visual system.
         No Apple asset, no SF font file, no copied SF Symbols file is embedded. -->

    <Color x:Key="SpdMacWindowColor">#F4F5F7</Color>
    <Color x:Key="SpdMacSidebarColor">#DDE2EA</Color>
    <Color x:Key="SpdMacPanelColor">#FDFDFE</Color>
    <Color x:Key="SpdMacTextColor">#111827</Color>
    <Color x:Key="SpdMacSecondaryTextColor">#667085</Color>
    <Color x:Key="SpdMacSeparatorColor">#301F2937</Color>

    <SolidColorBrush x:Key="SpdMacWindowBrush" Color="{StaticResource SpdMacWindowColor}"/>
    <SolidColorBrush x:Key="SpdMacSidebarBrush" Color="{StaticResource SpdMacSidebarColor}"/>
    <SolidColorBrush x:Key="SpdMacPanelBrush" Color="{StaticResource SpdMacPanelColor}"/>
    <SolidColorBrush x:Key="SpdMacTextBrush" Color="{StaticResource SpdMacTextColor}"/>
    <SolidColorBrush x:Key="SpdMacSecondaryTextBrush" Color="{StaticResource SpdMacSecondaryTextColor}"/>
    <SolidColorBrush x:Key="SpdMacSeparatorBrush" Color="{StaticResource SpdMacSeparatorColor}"/>

    <SolidColorBrush x:Key="SpdMacAccentBrush" Color="#0A84FF"/>
    <SolidColorBrush x:Key="SpdMacGreenBrush" Color="#34C759"/>
    <SolidColorBrush x:Key="SpdMacYellowBrush" Color="#FFCC00"/>
    <SolidColorBrush x:Key="SpdMacRedBrush" Color="#FF453A"/>

    <SolidColorBrush x:Key="SpdMacToolbarBrush" Color="#EEF1F6"/>
    <SolidColorBrush x:Key="SpdMacInspectorBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SpdMacSelectionBrush" Color="#220A84FF"/>
    <SolidColorBrush x:Key="SpdMacHoverBrush" Color="#14000000"/>


    <CornerRadius x:Key="SpdMacWindowCornerRadius">22</CornerRadius>
    <CornerRadius x:Key="SpdMacPanelCornerRadius">18</CornerRadius>
    <CornerRadius x:Key="SpdMacControlCornerRadius">10</CornerRadius>
    <Thickness x:Key="SpdMacPagePadding">28,24,32,28</Thickness>
    <Thickness x:Key="SpdMacCardPadding">18</Thickness>

    <Style x:Key="MacWindowPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SpdMacPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SpdMacSeparatorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource SpdMacPanelCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource SpdMacCardPadding}"/>
    </Style>

    <Style x:Key="MacSidebarButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="MacToolbarButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SpdMacToolbarBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SpdMacSeparatorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="MacSearchBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SpdMacPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SpdMacSeparatorBrush}"/>
        <Setter Property="PlaceholderForeground" Value="{StaticResource SpdMacSecondaryTextBrush}"/>
    </Style>

    <Style x:Key="MacSectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
    </Style>

    <Style x:Key="MacEmphasisValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
    </Style>

    <Style x:Key="MacSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacSecondaryTextBrush}"/>
        <Setter Property="Margin" Value="10,18,0,6"/>
    </Style>

    <Style x:Key="MacPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
    </Style>

    <Style x:Key="MacStatusCardStyle" TargetType="Border" BasedOn="{StaticResource MacWindowPanelStyle}">
        <Setter Property="MinHeight" Value="96"/>
    </Style>

    <!-- Premium macOS-inspired surfaces (v45 UI redesign) -->

    <LinearGradientBrush x:Key="SpdPremiumSidebarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E9EDF3" Offset="0"/>
        <GradientStop Color="#D8DEE8" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SpdPremiumWindowBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F6F7F9" Offset="0"/>
        <GradientStop Color="#EEF1F5" Offset="1"/>
    </LinearGradientBrush>

    <CornerRadius x:Key="SpdPremiumHeroCornerRadius">24</CornerRadius>
    <CornerRadius x:Key="SpdPremiumCardCornerRadius">20</CornerRadius>
    <Thickness x:Key="SpdPremiumCardPadding">24</Thickness>

    <Style x:Key="PremiumHeroCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SpdMacPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SpdMacSeparatorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource SpdPremiumHeroCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource SpdPremiumCardPadding}"/>
        <Setter Property="MinHeight" Value="140"/>
    </Style>

    <Style x:Key="PremiumAttentionCardStyle" TargetType="Border" BasedOn="{StaticResource PremiumHeroCardStyle}">
        <Setter Property="MinHeight" Value="72"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="CornerRadius" Value="{StaticResource SpdPremiumCardCornerRadius}"/>
        <Setter Property="Background" Value="#FFF9F0"/>
    </Style>

    <Style x:Key="PremiumPrimaryButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource SpdMacAccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="PremiumWindowButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="40"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="PremiumWindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource PremiumWindowButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
    </Style>
</ResourceDictionary>

<UserControl
    x:Class="SmartPerformanceDoctor.App.Controls.MacNavigationButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button x:Name="RootButton" Style="{StaticResource MacSidebarButtonStyle}">
        <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
            <TextBlock x:Name="SymbolText" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="{StaticResource SpdMacTextBrush}"/>
            <TextBlock x:Name="TitleText" Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource SpdMacTextBrush}"/>
        </Grid>
    </Button>
</UserControl>

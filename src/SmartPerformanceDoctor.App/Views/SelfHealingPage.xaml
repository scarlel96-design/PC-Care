<Page
    x:Class="SmartPerformanceDoctor.App.Views.SelfHealingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Padding="{StaticResource SpdMacPagePadding}" Spacing="18">
        <TextBlock Text="자가 복구" FontSize="34" FontWeight="SemiBold"/>
        <TextBlock Text="누락된 런타임 폴더와 필수 구성 요소를 점검하고 가능한 항목은 복구합니다."
                   Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
        <Border Style="{StaticResource MacWindowPanelStyle}">
            <StackPanel Spacing="12">
                <Button Content="자가 복구 검사" Click="RunSelfHealing"/>
                <ListView x:Name="ResultList" MinHeight="440">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="8">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource SpdMutedTextBrush}"/>
                                <TextBlock Text="{Binding Severity}" Foreground="{StaticResource SpdMutedTextBrush}"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Path}" Foreground="{StaticResource SpdMutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>

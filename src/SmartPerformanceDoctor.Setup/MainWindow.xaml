<Window x:Class="SmartPerformanceDoctor.Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC 케어 프로 설치"
        Width="920" Height="640"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SpdWindowBrush}">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SpdPanelBrush}" CornerRadius="18" Padding="18">
            <StackPanel>
                <TextBlock Text="PC 케어 프로" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource SpdTextBrush}"/>
                <TextBlock x:Name="VersionLine" Margin="0,6,0,18" Foreground="{StaticResource SpdMutedBrush}"/>
                <TextBlock x:Name="StepWelcome" Text="1. 시작" Margin="0,4"/>
                <TextBlock x:Name="StepEula" Text="2. 사용권" Margin="0,4" Foreground="{StaticResource SpdMutedBrush}"/>
                <TextBlock x:Name="StepConsent" Text="3. 동의" Margin="0,4" Foreground="{StaticResource SpdMutedBrush}"/>
                <TextBlock x:Name="StepFeatures" Text="4. 기능 선택" Margin="0,4" Foreground="{StaticResource SpdMutedBrush}"/>
                <TextBlock x:Name="StepWarnings" Text="5. 주의사항" Margin="0,4" Foreground="{StaticResource SpdMutedBrush}"/>
                <TextBlock x:Name="StepPath" Text="6. 설치 위치" Margin="0,4" Foreground="{StaticResource SpdMutedBrush}"/>
                <TextBlock x:Name="StepPreflight" Text="7. 환경 점검" Margin="0,4" Foreground="{StaticResource SpdMutedBrush}"/>
                <TextBlock x:Name="StepInstall" Text="8. 설치" Margin="0,4" Foreground="{StaticResource SpdMutedBrush}"/>
                <TextBlock x:Name="StepDone" Text="9. 완료" Margin="0,4" Foreground="{StaticResource SpdMutedBrush}"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="18,0,0,0" Background="{StaticResource SpdPanelBrush}" CornerRadius="18" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ContentPanel" MinHeight="420"/>
                </ScrollViewer>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="BackButton" Content="이전" Width="100" Margin="0,0,8,0" Style="{StaticResource SpdSecondaryButtonStyle}" Click="BackClick"/>
                    <Button x:Name="NextButton" Content="다음" Width="100" Style="{StaticResource SpdPrimaryButtonStyle}" Click="NextClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
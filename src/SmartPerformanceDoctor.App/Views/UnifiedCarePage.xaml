<Page
    x:Class="SmartPerformanceDoctor.App.Views.UnifiedCarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock Text="통합 점검" Style="{StaticResource MacPageTitleStyle}"/>
                <TextBlock Text="최신 진단 엔진 · 로컬 규칙 분석 · AI 요약 · 점검 보고서"
                           Foreground="{StaticResource SpdAccentBrush}" FontWeight="SemiBold"/>
                <TextBlock Text="점검 범위와 실행 방식을 선택한 뒤 검사를 시작하세요. 보고서는 프로그램 설치 폴더의 reports 에 저장됩니다."
                           Style="{StaticResource MacInlineStatusTextStyle}"/>
            </StackPanel>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="점검 설정" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="점검 범위" FontWeight="SemiBold"/>
                    <ComboBox x:Name="ScopeBox" SelectedIndex="0" SelectionChanged="ScopeChanged">
                        <ComboBoxItem Content="빠른 점검" Tag="quick"/>
                        <ComboBoxItem Content="시스템 점검" Tag="system"/>
                        <ComboBoxItem Content="드라이버" Tag="driver"/>
                        <ComboBoxItem Content="오디오" Tag="audio"/>
                        <ComboBoxItem Content="전체 점검 (빠른+시스템+드라이버+오디오)" Tag="full"/>
                    </ComboBox>

                    <TextBlock Text="실행 방식" FontWeight="SemiBold"/>
                    <RadioButton x:Name="DiagnosisOnlyRadio" Content="진단만 — PC에 변경 없음" GroupName="CareMode" Checked="ModeChanged"/>
                    <RadioButton x:Name="DiagnosisAndRepairRadio" Content="진단 + 복구 — 문제가 있으면 안전 복구까지 진행" GroupName="CareMode" Checked="ModeChanged"/>

                    <CheckBox x:Name="RiskCheck"
                              Content="복구 위험도와 대상을 확인했습니다. (복구 모드에서 필요)"
                              IsEnabled="False"
                              Checked="RiskChanged"
                              Unchecked="RiskChanged"/>
                    <TextBlock x:Name="ModeHintText"
                               Text="현재: 진단만 모드입니다. 복구 작업은 실행되지 않습니다."
                               Foreground="{StaticResource SpdMutedTextBrush}"
                               TextWrapping="Wrap"/>

                    <Button x:Name="StartButton" Content="검사 시작" Style="{StaticResource MacToolbarButtonStyle}" HorizontalAlignment="Left" Click="StartCare"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="진행 요약" FontSize="20" FontWeight="SemiBold"/>
                    <ProgressBar x:Name="ProgressBar" Maximum="100" Value="0"/>
                    <TextBlock x:Name="StatusText" Text="대기" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SummaryText" Text="점검 범위와 실행 방식을 선택한 뒤 [검사 시작]을 누르세요." TextWrapping="Wrap"/>
                    <TextBlock x:Name="SessionText" Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="최근 처리 단계"
                               Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                    <ListView x:Name="StepList" MaxHeight="220" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="10" CornerRadius="10" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                    <StackPanel Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ExecutionKind}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Phase}" Foreground="{StaticResource SpdMutedTextBrush}" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Foreground="{StaticResource SpdMutedTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
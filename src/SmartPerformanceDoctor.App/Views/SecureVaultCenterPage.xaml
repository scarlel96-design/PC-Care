<Page
    x:Class="SmartPerformanceDoctor.App.Views.SecureVaultCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <TextBlock Text="보안 금고" Style="{StaticResource MacPageTitleStyle}"/>
            <TextBlock Text="파일을 암호화해 안전하게 보관합니다."
                       Style="{StaticResource MacInlineStatusTextStyle}" TextWrapping="Wrap"/>
            <CheckBox x:Name="SealOriginCheckBox" Content="가져온 뒤 원본 삭제 (권장)" IsChecked="True"/>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="상태" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <TextBlock x:Name="StateLineText" Style="{StaticResource MacEmphasisValueStyle}"/>
                    <TextBlock x:Name="SecurityStateText" FontWeight="SemiBold" TextWrapping="Wrap"
                               Foreground="{StaticResource SpdAccentBrush}"/>
                    <TextBlock x:Name="SessionCountdownText" TextWrapping="Wrap" FontWeight="SemiBold"
                               Foreground="{StaticResource SpdAccentBrush}"/>
                    <TextBlock x:Name="StatusLineText" TextWrapping="Wrap" Style="{StaticResource MacInlineStatusTextStyle}"/>
                    <TextBlock x:Name="CryptoLineText"
                               Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                    <TextBlock x:Name="SecurityLineText"
                               Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border x:Name="CreatePanel" Style="{StaticResource MacWindowPanelStyle}" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="새 금고 만들기" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <PasswordBox x:Name="CreatePasswordBox" PlaceholderText="마스터 비밀번호 (12자+, 대소문자·숫자·특수문자)"/>
                    <PasswordBox x:Name="CreatePasswordConfirmBox" PlaceholderText="비밀번호 확인"/>
                    <TextBox x:Name="RecoveryHintBox" PlaceholderText="복구 힌트 (선택, 비밀번호 아님)"/>
                    <Button Content="금고 생성" Style="{StaticResource MacToolbarButtonStyle}" Click="CreateVault"/>
                </StackPanel>
            </Border>

            <Border x:Name="UnlockPanel" Style="{StaticResource MacWindowPanelStyle}" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="금고 열기" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <PasswordBox x:Name="UnlockPasswordBox" PlaceholderText="마스터 비밀번호"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="잠금 해제" Style="{StaticResource MacToolbarButtonStyle}" Click="UnlockVault"/>
                        <Button Content="읽기 전용으로 열기" Style="{StaticResource MacToolbarButtonStyle}" Click="UnlockReadOnly"
                                ToolTipService.ToolTip="가져오기·삭제는 불가, 내보내기만 가능 (v5 Lab)"/>
                    </StackPanel>
                    <TextBlock Text="복구 코드로 열기" Style="{StaticResource MacSectionHeaderStyle}" Margin="0,8,0,0"/>
                    <TextBlock x:Name="RecoveryHintText" TextWrapping="Wrap"
                               Foreground="{StaticResource SpdMutedTextBrush}"
                               Text="일회용 코드 · 사용 후 소진 · 성공 시 복구 세션(비밀번호 변경 권고)"/>
                    <TextBox x:Name="RecoveryKeyBox" PlaceholderText="XXXX-XXXX-XXXX-XXXX (일회용 복구 코드)"/>
                    <Button Content="복구 코드 잠금 해제" Style="{StaticResource MacToolbarButtonStyle}" Click="UnlockWithRecoveryKey"/>
                </StackPanel>
            </Border>

            <Border x:Name="UnlockedPanel" Style="{StaticResource MacWindowPanelStyle}" Visibility="Collapsed">
                <StackPanel x:Name="UnlockedActionsPanel" Spacing="10">
                    <TextBlock Text="보관 항목" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="파일 넣기" Style="{StaticResource MacToolbarButtonStyle}" Click="AddFile"/>
                        <Button Content="폴더 넣기" Style="{StaticResource MacToolbarButtonStyle}" Click="AddFolder"/>
                        <Button x:Name="BackButton" Content="뒤로" Style="{StaticResource MacToolbarButtonStyle}" Click="NavigateBack" Visibility="Collapsed"/>
                        <Button Content="잠그기" Style="{StaticResource MacToolbarButtonStyle}" Click="LockVault"/>
                        <Button Content="무결성 검사" Style="{StaticResource MacToolbarButtonStyle}" Click="VerifyIntegrity"/>
                        <Button Content="Pack 정리(GC)" Style="{StaticResource MacToolbarButtonStyle}" Click="CompactPacks"
                                ToolTipService.ToolTip="v5 pack 파일 재패킹·tombstone 제거 (쓰기 세션 필요)"/>
                        <Button Content="Activation 복구" Style="{StaticResource MacToolbarButtonStyle}" Click="RepairActivation"
                                ToolTipService.ToolTip="activation.commit 마커를 현재 메타 해시로 재작성 (v5 Lab)"/>
                        <Button Content="비밀번호 변경" Style="{StaticResource MacToolbarButtonStyle}" Click="ChangePassword"
                                ToolTipService.ToolTip="변경 시 이전 복구 코드 전부 무효 · 새 코드 10개 발급"/>
                        <Button Content="복구 코드 재발급" Style="{StaticResource MacToolbarButtonStyle}" Click="ReissueRecoveryCodes"
                                ToolTipService.ToolTip="비밀번호 확인 후 일회용 복구 코드 10개 재발급 (이전 코드 무효, v5 Lab)"/>
                        <Button Content="v3→v4 마이그레이션" Style="{StaticResource MacToolbarButtonStyle}" Click="MigrateToLabV4"
                                ToolTipService.ToolTip="레거시 v3 금고를 Lab v4로 재암호화 복사 (원본 유지)"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="자동 잠금 (분):" VerticalAlignment="Center"/>
                        <ComboBox x:Name="AutoLockMinutesBox" Width="88" SelectionChanged="AutoLockMinutesChanged"/>
                    </StackPanel>
                    <TextBlock x:Name="BreadcrumbText" FontWeight="SemiBold"/>
                    <ListView x:Name="EntryList" MinHeight="240" SelectionMode="Single" DoubleTapped="EntryDoubleTapped">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Padding="0,4">
                                    <TextBlock Text="{Binding TitleLine}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DetailLine}" Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="열기" Style="{StaticResource MacToolbarButtonStyle}" Click="OpenSelectedEntry"/>
                        <Button Content="원본 복원" Style="{StaticResource MacToolbarButtonStyle}" Click="RestoreToOrigin"/>
                        <Button Content="다른 위치로 보내기" Style="{StaticResource MacToolbarButtonStyle}" Click="ExportEntry"/>
                        <Button Content="보안 삭제" Style="{StaticResource MacToolbarButtonStyle}" Click="RemoveFromVault"/>
                    </StackPanel>
                    <TextBlock Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"
                               Text="최상위 폴더(🔒📁)를 선택한 뒤 원본 복원 · 더블클릭: 폴더 안으로 들어가기 · 보안 삭제: 복원 없이 데이터 파기"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
<Window x:Class="SmartPerformanceDoctor.Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC 케어 프로 설치" Width="980" Height="680" MinWidth="860" MinHeight="600"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI Variable Text, Malgun Gothic"
        Background="{StaticResource SpdWindowBrush}">
    <Grid Margin="22">
        <Grid.ColumnDefinitions><ColumnDefinition Width="224"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" CornerRadius="24" Padding="22">
            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#0877E8" Offset="0"/><GradientStop Color="#3157D6" Offset="0.58"/><GradientStop Color="#5948C8" Offset="1"/></LinearGradientBrush></Border.Background>
            <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.18" Color="#3157D6"/></Border.Effect>
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel>
                    <Border Width="42" Height="42" HorizontalAlignment="Left" CornerRadius="13" Background="#26FFFFFF"><TextBlock Text="P" Foreground="White" FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <TextBlock Text="PC 케어 프로" Margin="0,14,0,0" FontSize="19" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="안전한 설치 도우미" Margin="0,4,0,0" FontSize="12" Foreground="#DDEBFF"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Margin="0,34,0,0">
                    <TextBlock x:Name="StepWelcome" Text="01  시작" Style="{StaticResource SpdInstallerStepStyle}"/>
                    <TextBlock x:Name="StepEula" Text="02  약관 및 동의" Style="{StaticResource SpdInstallerStepStyle}"/>
                    <TextBlock x:Name="StepFeatures" Text="03  설치 구성" Style="{StaticResource SpdInstallerStepStyle}"/>
                    <TextBlock x:Name="StepPreflight" Text="04  준비 확인" Style="{StaticResource SpdInstallerStepStyle}"/>
                    <TextBlock x:Name="StepInstall" Text="05  설치 진행" Style="{StaticResource SpdInstallerStepStyle}"/>
                    <TextBlock x:Name="StepDone" Text="06  완료" Style="{StaticResource SpdInstallerStepStyle}"/>
                </StackPanel>
                <StackPanel Grid.Row="2"><TextBlock x:Name="VersionLine" Foreground="#DDEBFF" FontSize="11" TextWrapping="Wrap"/><TextBlock Text="로컬 설치 · 사용자 승인 기반" Margin="0,6,0,0" Foreground="#BFD5F7" FontSize="10"/></StackPanel>
            </Grid>
        </Border>
        <Border Grid.Column="1" Margin="18,0,0,0" Background="{StaticResource SpdPanelBrush}" BorderBrush="{StaticResource SpdPanelBorderBrush}" BorderThickness="1" CornerRadius="24" Padding="28,24,28,22">
            <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.08" Color="#172B4D"/></Border.Effect>
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid Margin="0,0,0,18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel><TextBlock x:Name="StepCounterLine" Text="1 / 6" Foreground="{StaticResource SpdAccentBrush}" FontSize="12" FontWeight="SemiBold"/><TextBlock x:Name="StepTitleLine" Text="시작" Margin="0,4,0,0" Foreground="{StaticResource SpdTextBrush}" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                        <Border Grid.Column="1" Background="{StaticResource SpdAccentSoftBrush}" CornerRadius="12" Padding="10,6"><TextBlock Text="v51.0.2" Foreground="{StaticResource SpdAccentBrush}" FontSize="11" FontWeight="SemiBold"/></Border>
                    </Grid>
                    <ProgressBar x:Name="StepProgressBar" Grid.Row="1" Height="5" Margin="0,14,0,0" Minimum="0" Maximum="6" Value="1" Style="{StaticResource SpdThinProgressStyle}"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"><StackPanel x:Name="ContentPanel" MinHeight="410" Margin="2,0,8,0"/></ScrollViewer>
                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <TextBlock Text="설치 중에는 창을 닫지 마세요." VerticalAlignment="Center" Foreground="{StaticResource SpdMutedBrush}" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button x:Name="BackButton" Content="이전" MinWidth="104" Margin="0,0,10,0" Style="{StaticResource SpdSecondaryButtonStyle}" Click="BackClick"/><Button x:Name="NextButton" Content="다음" MinWidth="112" Style="{StaticResource SpdPrimaryButtonStyle}" Click="NextClick"/></StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
<Page
    x:Class="SmartPerformanceDoctor.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Spacing="18">
            <TextBlock Text="FullChange Intelligence Console"
                       FontSize="34" FontWeight="SemiBold"/>
            <TextBlock Text="시스템, 드라이버, 오디오, 이벤트, 보안 상태를 상관 분석하고 안전한 복구 계획을 생성합니다."
                       Foreground="{StaticResource SpdMutedTextBrush}"
                       FontSize="15"/>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource MetricCardStyle}" Grid.Column="0">
                    <StackPanel>
                        <TextBlock Text="시스템 상태" Foreground="{StaticResource SpdMutedTextBrush}"/>
                        <TextBlock Text="대기 중" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Grid.Column="1">
                    <StackPanel>
                        <TextBlock Text="엔진" Foreground="{StaticResource SpdMutedTextBrush}"/>
                        <TextBlock Text="v16" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Grid.Column="2">
                    <StackPanel>
                        <TextBlock Text="보안" Foreground="{StaticResource SpdMutedTextBrush}"/>
                        <TextBlock Text="DPAPI" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Grid.Column="3">
                    <StackPanel>
                        <TextBlock Text="복구 정책" Foreground="{StaticResource SpdMutedTextBrush}"/>
                        <TextBlock Text="진단 우선" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="진단 흐름" FontSize="22" FontWeight="SemiBold"/>
                    <ProgressBar Value="0" Maximum="100"/>
                    <TextBlock Text="아직 작업이 시작되지 않았습니다."/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="원인 추론" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="진단 결과가 수집되면 Intelligence Engine이 원인 후보와 해결 순서를 계산합니다."
                               Foreground="{StaticResource SpdMutedTextBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Legacy resource aliases aligned with v34 macOS light shell.
         Kept for pages that still reference ThemeResource Spd* keys. -->

    <SolidColorBrush x:Key="SpdBackgroundBrush" Color="#F4F5F7"/>
    <SolidColorBrush x:Key="SpdSidebarBrush" Color="#DDE2EA"/>
    <SolidColorBrush x:Key="SpdPanelBrush" Color="#FDFDFE"/>
    <SolidColorBrush x:Key="SpdCardBrush" Color="#FDFDFE"/>
    <SolidColorBrush x:Key="SpdTextBrush" Color="#111827"/>
    <SolidColorBrush x:Key="SpdMutedTextBrush" Color="#667085"/>
    <SolidColorBrush x:Key="SpdAccentBrush" Color="#0A84FF"/>
    <SolidColorBrush x:Key="SpdSeparatorBrush" Color="#301F2937"/>

    <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource MacWindowPanelStyle}">
        <Setter Property="MinHeight" Value="96"/>
    </Style>

    <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource MacSidebarButtonStyle}"/>

    <!-- Loaded after XamlControlsResources so light-theme text wins over system dark mode. -->
    <Style TargetType="Page">
        <Setter Property="Background" Value="{StaticResource SpdMacWindowBrush}"/>
        <Setter Property="RequestedTheme" Value="Light"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SpdMacToolbarBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SpdMacSeparatorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SpdMacPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SpdMacSeparatorBrush}"/>
        <Setter Property="PlaceholderForeground" Value="{StaticResource SpdMacSecondaryTextBrush}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SpdMacPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SpdMacSeparatorBrush}"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
    </Style>

    <Style TargetType="ListView">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="UserControl">
        <Setter Property="RequestedTheme" Value="Light"/>
    </Style>

</ResourceDictionary>
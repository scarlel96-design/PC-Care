<Page
    x:Class="SmartPerformanceDoctor.App.Views.ProgramProtectionCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="프로그램 보호 · 복구 미러" Style="{StaticResource MacPageTitleStyle}"/>
                    <TextBlock Text="설정 화면에 들어가지 않아도 백그라운드에서 무결성을 감시하고 손상 시 자동 복구합니다."
                               Style="{StaticResource MacInlineStatusTextStyle}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="지금 검사" Style="{StaticResource MacToolbarButtonStyle}" Click="Verify"/>
                    <Button Content="오프라인 캡슐" Style="{StaticResource MacToolbarButtonStyle}" Click="ExportOfflineCapsule"/>
                    <Button Content="기준선 재생성" Style="{StaticResource MacToolbarButtonStyle}" Click="RebuildBaseline"/>
                </StackPanel>
            </Grid>

            <Border x:Name="AutoProtectionBanner"
                    Background="#FFE8F5E9"
                    BorderBrush="#FFA5D6A7"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <FontIcon x:Name="AutoProtectionIcon" Glyph="&#xE7BA;" FontSize="22" Foreground="#FF2E7D32" VerticalAlignment="Center"/>
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="AutoProtectionTitle"
                                   Text="상시 자동 보호 활성"
                                   FontWeight="SemiBold"
                                   Foreground="#FF1B5E20"/>
                        <TextBlock x:Name="AutoProtectionDetail"
                                   TextWrapping="Wrap"
                                   Foreground="#FF2E7D32"/>
                    </StackPanel>
                    <Border x:Name="AutoProtectionBadgeBorder" Background="#FF2E7D32" CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
                        <TextBlock x:Name="AutoProtectionBadge" Text="AUTO" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="SafeModeWarningPanel"
                    Background="#FFFFF3E0"
                    BorderBrush="#FFFFCC80"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Visibility="Collapsed">
                <StackPanel Spacing="6">
                    <TextBlock Text="안전 모드 활성"
                               FontWeight="SemiBold"
                               Foreground="#FFB45309"/>
                    <TextBlock x:Name="SafeModeWarningText"
                               TextWrapping="Wrap"
                               Foreground="#FF92400E"/>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="1.2*,1.8*" ColumnSpacing="16">
                <Border Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="보호 등급" Style="{StaticResource MacSectionHeaderStyle}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock x:Name="ProtectionLevelValue" FontSize="36" FontWeight="Bold" Foreground="{StaticResource SpdAccentBrush}"/>
                            <TextBlock Text="/ 5" FontSize="20" Foreground="{StaticResource SpdMutedTextBrush}" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                        </StackPanel>
                        <Grid x:Name="ProtectionLevelStrip" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6" Height="10" Margin="0,2,0,10">
                            <Border x:Name="LevelSeg1" CornerRadius="4" Background="{StaticResource SpdMacSeparatorBrush}"/>
                            <Border x:Name="LevelSeg2" Grid.Column="1" CornerRadius="4" Background="{StaticResource SpdMacSeparatorBrush}"/>
                            <Border x:Name="LevelSeg3" Grid.Column="2" CornerRadius="4" Background="{StaticResource SpdMacSeparatorBrush}"/>
                            <Border x:Name="LevelSeg4" Grid.Column="3" CornerRadius="4" Background="{StaticResource SpdMacSeparatorBrush}"/>
                            <Border x:Name="LevelSeg5" Grid.Column="4" CornerRadius="4" Background="{StaticResource SpdMacSeparatorBrush}"/>
                        </Grid>
                        <TextBlock x:Name="ProtectionLevelCaption" Style="{StaticResource MacInlineStatusTextStyle}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock x:Name="MirrorStatusText" Style="{StaticResource MacEmphasisValueStyle}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="MirrorDetailText" Style="{StaticResource MacInlineStatusTextStyle}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="보호 구성요소" Style="{StaticResource MacSectionHeaderStyle}"/>
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <Border x:Name="ChipManifest" Grid.Row="0" Grid.Column="0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="매니페스트" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="ChipManifestValue" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipCapsule" Grid.Row="0" Grid.Column="1" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="복구 캡슐" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="ChipCapsuleValue" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipAudit" Grid.Row="0" Grid.Column="2" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="감사 체인" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="ChipAuditValue" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipService" Grid.Row="1" Grid.Column="0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="복구 서비스" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="ChipServiceValue" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipBackup" Grid.Row="1" Grid.Column="1" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="백업 슬롯" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="ChipBackupValue" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipOffline" Grid.Row="1" Grid.Column="2" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="오프라인 팩" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="ChipOfflineValue" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipTpm" Grid.Row="2" Grid.Column="0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="키 보호" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="ChipTpmValue" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipSigning" Grid.Row="2" Grid.Column="1" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="서명 키" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="ChipSigningValue" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipMirrorPath" Grid.Row="2" Grid.Column="2" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="미러 저장소" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="ChipMirrorPathValue" Style="{StaticResource MacListItemSubtitleStyle}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="설치 무결성" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <TextBlock x:Name="StatusText" Style="{StaticResource MacEmphasisValueStyle}"/>
                    <TextBlock x:Name="ExeHashText" Style="{StaticResource MacInlineStatusTextStyle}" TextWrapping="Wrap"/>
                    <TextBlock Text="감지 내역" Style="{StaticResource MacSectionHeaderStyle}" Margin="0,4,0,0"/>
                    <ListView x:Name="FindingList" MinHeight="180" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Style="{StaticResource MacInlineStatusTextStyle}"/>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="AegisDisclaimerText" Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
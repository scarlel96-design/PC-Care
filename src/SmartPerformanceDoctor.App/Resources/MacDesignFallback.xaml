<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- v35 compile hardening fallback.
         This keeps legacy resource names working while pages move toward macOS-style resources. -->

    <SolidColorBrush x:Key="SpdMutedTextBrush" Color="#667085"/>
    <SolidColorBrush x:Key="SpdTextBrush" Color="#111827"/>
    <SolidColorBrush x:Key="SpdPanelBrush" Color="#FDFDFE"/>
    <SolidColorBrush x:Key="SpdSeparatorBrush" Color="#301F2937"/>

    <Style x:Key="GlassPanelStyle" TargetType="Border" BasedOn="{StaticResource MacWindowPanelStyle}"/>

    <Style x:Key="MacPageRootStackStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="18"/>
    </Style>

    <Style x:Key="MacListItemTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacTextBrush}"/>
    </Style>

    <Style x:Key="MacListItemSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacSecondaryTextBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="MacInlineStatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource SpdMacSecondaryTextBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
</ResourceDictionary>

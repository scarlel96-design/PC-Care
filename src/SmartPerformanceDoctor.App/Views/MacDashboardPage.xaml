<Page
    x:Class="SmartPerformanceDoctor.App.Views.MacDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" MaxWidth="1040" Style="{StaticResource MacPageRootStackStyle}">
            <Border Style="{StaticResource PremiumHeroCardStyle}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="24">
                    <StackPanel VerticalAlignment="Center" MinWidth="120">
                        <TextBlock Text="{Binding HealthScore}" FontSize="44" FontWeight="SemiBold"
                                   Foreground="{StaticResource SpdMacAccentBrush}"/>
                        <TextBlock Text="상태 점수" FontSize="13" Foreground="{StaticResource SpdMacSecondaryTextBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="{Binding OverallStatus}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{StaticResource SpdMacTextBrush}"/>
                        <TextBlock Text="{Binding Summary}" Style="{StaticResource MacInlineStatusTextStyle}"/>
                        <ItemsControl ItemsSource="{Binding TopIssues}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Margin="0,2,0,0" FontSize="13"
                                               Foreground="{StaticResource SpdMacSecondaryTextBrush}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="정밀 점검 시작" Style="{StaticResource PremiumPrimaryButtonStyle}"
                                HorizontalAlignment="Left" Margin="0,8,0,0" Click="StartDeepScan"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="빠른 작업" Style="{StaticResource MacSectionHeaderStyle}"/>
            <ItemsControl ItemsSource="{Binding QuickActions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid MaximumRowsOrColumns="3" Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Title}" Width="300" Margin="0,0,12,12"
                                Style="{StaticResource MacToolbarButtonStyle}" Click="QuickActionClick" Tag="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="주의가 필요한 항목" Style="{StaticResource MacSectionHeaderStyle}"
                       Visibility="{Binding AttentionCardsVisibility}"/>
            <ItemsControl ItemsSource="{Binding AttentionCards}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PremiumAttentionCardStyle}" Margin="0,0,0,12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Title}" Style="{StaticResource MacListItemTitleStyle}"/>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource MacListItemSubtitleStyle}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="최근 보고서" Style="{StaticResource MacSectionHeaderStyle}"/>
            <ItemsControl ItemsSource="{Binding RecentReports}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource MacWindowPanelStyle}" Margin="0,0,0,10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Title}" Style="{StaticResource MacListItemTitleStyle}"/>
                                <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MacListItemSubtitleStyle}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="추천 다음 작업" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <TextBlock Text="{Binding PrimaryRecommendation.Title}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PrimaryRecommendation.Description}" Style="{StaticResource MacInlineStatusTextStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{Binding PrimaryRecommendation.Title}" Style="{StaticResource PremiumPrimaryButtonStyle}" Click="PrimaryActionClick"/>
                        <Button Content="새로 고침" Style="{StaticResource MacToolbarButtonStyle}" Click="RefreshDashboard"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
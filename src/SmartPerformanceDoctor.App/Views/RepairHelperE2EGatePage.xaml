<Page
    x:Class="SmartPerformanceDoctor.App.Views.RepairHelperE2EGatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="복구 품질 점검" Style="{StaticResource MacPageTitleStyle}"/>
                    <TextBlock Text="관리자 권한, 통신 채널, 시뮬레이션 실행, 승인 절차, 로그·증거 경로를 전체 흐름으로 점검합니다."
                               Style="{StaticResource MacInlineStatusTextStyle}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="시뮬레이션 점검 실행" Style="{StaticResource MacToolbarButtonStyle}" Click="RunGate"/>
            </Grid>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Status}" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Summary}" Style="{StaticResource MacInlineStatusTextStyle}"/>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="1.4*,1*" ColumnSpacing="16">
                <Border Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="복구 작업 점검 결과" FontSize="20" FontWeight="SemiBold"/>
                        <ListView ItemsSource="{Binding Checks}" Style="{StaticResource StableLogListViewStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StableLogItemPanelStyle}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Action}" Style="{StaticResource StableLogTitleTextStyle}"/>
                                                <TextBlock Text="{Binding Message}" Style="{StaticResource StableLogPreviewTextStyle}"/>
                                                <TextBlock Text="{Binding EvidencePath}" Style="{StaticResource StableLogMetaTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="3">
                                                <TextBlock Text="{Binding Area}" Style="{StaticResource StableLogMetaTextStyle}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Severity}" Style="{StaticResource StableLogMetaTextStyle}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="원인 분석 점수" FontSize="20" FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding Scores}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="10" CornerRadius="10" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Area}" Style="{StaticResource MacListItemTitleStyle}"/>
                                            <TextBlock Text="{Binding Score}" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Severity}" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                            <TextBlock Text="{Binding Explanation}" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>

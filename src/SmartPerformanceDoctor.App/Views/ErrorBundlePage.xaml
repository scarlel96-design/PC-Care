<Page
    x:Class="SmartPerformanceDoctor.App.Views.ErrorBundlePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Padding="{StaticResource SpdMacPagePadding}" Spacing="18">
        <TextBlock Text="오류 번들" FontSize="34" FontWeight="SemiBold"/>
        <TextBlock Text="빌드/실행 문제를 전달하기 위한 보고서, 복구 로그, 환경 정보를 ZIP으로 묶습니다."
                   Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
        <Border Style="{StaticResource MacWindowPanelStyle}">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="수집 대상 다시 검사" Click="RefreshSources"/>
                    <Button Content="오류 번들 생성" Click="CreateErrorBundle"/>
                    <Button Content="오류 번들 폴더 열기" Click="OpenBundleFolder"/>
                </StackPanel>
                <ListView x:Name="SourceList" MinHeight="360">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="8">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource SpdMutedTextBrush}"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Path}" Foreground="{StaticResource SpdMutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock x:Name="StatusText" Text="오류 번들을 생성하면 경로가 여기에 표시됩니다." TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>

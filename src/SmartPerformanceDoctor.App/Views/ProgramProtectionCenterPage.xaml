<Page
    x:Class="SmartPerformanceDoctor.App.Views.ProgramProtectionCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="프로그램 보호 · 복구 미러" Style="{StaticResource MacPageTitleStyle}"/>
                <Button Grid.Column="1" Content="무결성 검사" Style="{StaticResource MacToolbarButtonStyle}" Click="Verify"/>
                <Button Grid.Column="2" Content="오프라인 캡슐" Style="{StaticResource MacToolbarButtonStyle}" Click="ExportOfflineCapsule"/>
                <Button Grid.Column="3" Content="기준선 재생성" Style="{StaticResource MacToolbarButtonStyle}" Click="RebuildBaseline"/>
            </Grid>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="복구 미러 상태" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <TextBlock x:Name="MirrorStatusText" Style="{StaticResource MacEmphasisValueStyle}" TextWrapping="Wrap"/>
                    <TextBlock x:Name="MirrorDetailText" Style="{StaticResource MacInlineStatusTextStyle}" TextWrapping="Wrap"/>
                    <TextBlock x:Name="AegisDisclaimerText" Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="설치 무결성" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <TextBlock x:Name="StatusText" Style="{StaticResource MacEmphasisValueStyle}"/>
                    <TextBlock x:Name="ExeHashText" Style="{StaticResource MacInlineStatusTextStyle}" TextWrapping="Wrap"/>
                    <ListView x:Name="FindingList" MinHeight="160" SelectionMode="None"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
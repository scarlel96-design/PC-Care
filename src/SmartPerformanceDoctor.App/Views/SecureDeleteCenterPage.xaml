<Page
    x:Class="SmartPerformanceDoctor.App.Views.SecureDeleteCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource PccPagePadding}" MaxWidth="960" Spacing="18">
            <StackPanel Spacing="5">
                <TextBlock Text="보안 삭제" Style="{StaticResource MacPageTitleStyle}"/>
                <TextBlock Text="대상을 미리 검증한 다음 복구하기 어려운 방식으로 삭제합니다."
                           Style="{StaticResource MacInlineStatusTextStyle}" TextWrapping="Wrap"/>
            </StackPanel>

            <Border Background="{StaticResource PccDangerSoftBrush}" BorderBrush="#35D84449"
                    BorderThickness="1" CornerRadius="18" Padding="20">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource PccDangerBrush}">
                        <TextBlock Text="!" Foreground="White" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock Text="삭제 후 되돌릴 수 없습니다" Foreground="{StaticResource PccDangerBrush}" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="HDD는 파일 영역 덮어쓰기를 적용합니다. SSD/NVMe는 웨어 레벨링·TRIM·컨트롤러 매핑 때문에 파일 단위 덮어쓰기로 물리 셀 삭제를 보장할 수 없습니다. 클라우드·백업·섀도 복사본도 별도입니다."
                                   Foreground="{StaticResource PccTextBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="13">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border Width="34" Height="34" CornerRadius="17" Background="{StaticResource PccAccentSoftBrush}">
                            <TextBlock Text="1" Foreground="{StaticResource PccAccentBrush}" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="파일과 폴더를 구분해 추가하세요" Style="{StaticResource MacSectionHeaderStyle}" VerticalAlignment="Center"/>
                    </Grid>
                    <ComboBox x:Name="SecurityLevelBox" SelectedIndex="1" SelectionChanged="SecurityLevelChanged"
                              AutomationProperties.Name="보안 삭제 등급">
                        <ComboBoxItem Content="표준 — HDD 1패스" Tag="Standard"/>
                        <ComboBoxItem Content="전문 — HDD 3패스 (권장)" Tag="Professional"/>
                        <ComboBoxItem Content="최대 — HDD 7패스" Tag="Maximum"/>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="AddFilesButton" Content="파일 추가" Style="{StaticResource PremiumPrimaryButtonStyle}"
                                Click="AddFiles" AutomationProperties.Name="보안 삭제 파일 추가"/>
                        <Button x:Name="AddFolderButton" Content="폴더 추가" Style="{StaticResource MacToolbarButtonStyle}"
                                Click="AddFolder" AutomationProperties.Name="보안 삭제 폴더 추가"/>
                        <Button x:Name="RemoveSelectedButton" Content="선택 제거" Style="{StaticResource MacToolbarButtonStyle}"
                                Click="RemoveSelectedTarget" AutomationProperties.Name="선택한 보안 삭제 대상 제거"/>
                        <Button x:Name="ClearTargetsButton" Content="전체 제거" Style="{StaticResource MacToolbarButtonStyle}"
                                Click="ClearTargets" AutomationProperties.Name="보안 삭제 대상 전체 제거"/>
                    </StackPanel>
                    <TextBlock x:Name="PlanSummaryText" TextWrapping="Wrap" FontWeight="SemiBold"/>
                    <ListView x:Name="TargetList" MinHeight="150" MaxHeight="300" SelectionMode="Single"
                              DisplayMemberPath="DisplayLine" AutomationProperties.Name="보안 삭제 대상 목록"/>
                    <Button x:Name="DryRunButton" Content="선택 항목 검사 · Dry Run" Style="{StaticResource PremiumPrimaryButtonStyle}"
                            Click="RunDryRun" HorizontalAlignment="Left" AutomationProperties.Name="보안 삭제 대상 미리 검사"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="13">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border Width="34" Height="34" CornerRadius="17" Background="{StaticResource PccDangerSoftBrush}">
                            <TextBlock Text="2" Foreground="{StaticResource PccDangerBrush}" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="최종 확인 후 삭제하세요" Style="{StaticResource MacSectionHeaderStyle}" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="계속하려면 ‘보안 삭제에 동의합니다’를 정확히 입력하세요."
                               Foreground="{StaticResource PccTextMutedBrush}" TextWrapping="Wrap"/>
                    <TextBox x:Name="ConfirmBox" PlaceholderText="보안 삭제에 동의합니다"
                             AutomationProperties.Name="보안 삭제 확인 문구"/>
                    <ProgressBar x:Name="ProgressBar" Maximum="100" Height="10"/>
                    <TextBlock x:Name="StatusText" TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Assertive" AutomationProperties.Name="보안 삭제 상태"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ApplyDeleteButton" Content="보안 삭제 실행" Style="{StaticResource PccDangerButtonStyle}"
                                Click="ApplyDelete" AutomationProperties.Name="보안 삭제 실행"/>
                        <Button x:Name="CancelDeleteButton" Content="작업 취소" Style="{StaticResource MacToolbarButtonStyle}"
                                Click="CancelDelete" Visibility="Collapsed" AutomationProperties.Name="보안 삭제 작업 취소"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
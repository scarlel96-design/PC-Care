<Page
    x:Class="SmartPerformanceDoctor.App.Views.FinalLockPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="최종 잠금 확인" Style="{StaticResource MacPageTitleStyle}"/>
                    <TextBlock Text="v44 배포 전 필수 점검 항목과 수동 확인 목록을 한곳에서 검토합니다."
                               Style="{StaticResource MacInlineStatusTextStyle}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="잠금 점검 실행" Style="{StaticResource MacToolbarButtonStyle}" Click="RunFinalLock"/>
            </Grid>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Status}" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Confidence}" Style="{StaticResource MacInlineStatusTextStyle}"/>
                    <TextBlock Text="{Binding Summary}" Style="{StaticResource MacInlineStatusTextStyle}"/>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="1.3*,1*" ColumnSpacing="16">
                <Border Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="최종 점검 항목" FontSize="20" FontWeight="SemiBold"/>
                        <ListView ItemsSource="{Binding Gates}" Style="{StaticResource StableLogListViewStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StableLogItemPanelStyle}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource StableLogTitleTextStyle}"/>
                                                <TextBlock Text="{Binding Message}" Style="{StaticResource StableLogPreviewTextStyle}"/>
                                                <TextBlock Text="{Binding Evidence}" Style="{StaticResource StableLogMetaTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Severity}" Style="{StaticResource StableLogMetaTextStyle}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource MacWindowPanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="완료 기준" FontSize="20" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding AcceptanceCriteria}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Margin="0,0,0,8" Style="{StaticResource MacInlineStatusTextStyle}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MacWindowPanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="수동 확인 항목" FontSize="20" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding RemainingManualChecks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Margin="0,0,0,8" Style="{StaticResource MacInlineStatusTextStyle}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>

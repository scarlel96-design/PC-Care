<Page
    x:Class="SmartPerformanceDoctor.App.Views.ProgressHudPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="진행 상황" Style="{StaticResource MacPageTitleStyle}"/>
                    <TextBlock Text="점검·복구·보고서 생성 같은 오래 걸리는 작업의 진행 상태를 보여줍니다."
                               Style="{StaticResource MacInlineStatusTextStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="새로 고침" Style="{StaticResource MacToolbarButtonStyle}" Click="RefreshProgress"/>
                    <Button Content="진단 엔진 테스트" Style="{StaticResource MacToolbarButtonStyle}" Click="SimulateCoreProbe"/>
                    <Button Content="지우기" Style="{StaticResource MacToolbarButtonStyle}" Click="ClearProgress"/>
                </StackPanel>
            </Grid>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding OverallStatus}" FontSize="24" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding OverallProgress}"/>
                    <TextBlock Text="{Binding ActiveOperationId}" Style="{StaticResource MacInlineStatusTextStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="실시간 기록" FontSize="20" FontWeight="SemiBold"/>
                    <ItemsControl ItemsSource="{Binding Events}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="10" CornerRadius="10" BorderThickness="1" BorderBrush="{StaticResource SpdMacSeparatorBrush}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Message}" Style="{StaticResource MacListItemTitleStyle}"/>
                                            <TextBlock Text="{Binding Phase}" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                            <TextBlock Text="{Binding Source}" Style="{StaticResource MacListItemSubtitleStyle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="3">
                                            <TextBlock Text="{Binding Status}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Progress}" Style="{StaticResource MacListItemSubtitleStyle}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Timestamp}" Style="{StaticResource MacListItemSubtitleStyle}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

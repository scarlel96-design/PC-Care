<Page
    x:Class="SmartPerformanceDoctor.App.Views.SystemCareCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <TextBlock Text="시스템 케어" Style="{StaticResource MacPageTitleStyle}"/>
            <TextBlock Text="통합 점검과 별도로 동작합니다. 건강 점수 · HMAC 감사 체인 · 격리 롤백 지원."
                       Style="{StaticResource MacInlineStatusTextStyle}"/>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="검사 방식" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <RadioButton x:Name="SmartScanRadio" Content="스마트 검사" GroupName="CareScanMode" Checked="ScanModeChanged"/>
                        <RadioButton x:Name="PrecisionScanRadio" Content="정밀 점검" GroupName="CareScanMode" Checked="ScanModeChanged"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusLine}" TextWrapping="Wrap" Style="{StaticResource MacInlineStatusTextStyle}"/>
                </StackPanel>
            </Border>

            <Border x:Name="TaskChecklistPanel" Style="{StaticResource MacWindowPanelStyle}" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBlock Text="검사 항목 선택" Style="{StaticResource MacSectionHeaderStyle}"/>
                        <Button Grid.Column="1" Content="전체 선택" Style="{StaticResource MacToolbarButtonStyle}" Click="SelectAllTasks"/>
                        <Button Grid.Column="2" Content="전체 해제" Style="{StaticResource MacToolbarButtonStyle}" Click="ClearAllTasks"/>
                    </Grid>
                    <TextBlock Text="체크한 항목만 검사합니다."
                               Foreground="{StaticResource SpdMutedTextBrush}"/>
                    <ListView ItemsSource="{Binding ScanTasks}" MinHeight="280" MaxHeight="420" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,4">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{StaticResource SpdMutedTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="검사 실행" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <Button Content="검사 시작" Style="{StaticResource MacToolbarButtonStyle}" Click="StartScan"/>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" Height="8"/>
                    <TextBlock Text="{Binding ProgressLine}" Style="{StaticResource MacListItemSubtitleStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="검사 결과" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <TextBlock Text="{Binding SummaryLine}" Style="{StaticResource MacEmphasisValueStyle}"/>
                    <TextBlock Text="{Binding HealthLine}" Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                    <ListView ItemsSource="{Binding FindingLines}" MinHeight="200" MaxHeight="320" SelectionMode="None"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="적용" Style="{StaticResource MacSectionHeaderStyle}"/>
                    <TextBlock Text="안전한 항목만 기본 적용합니다. 삭제 전 격리 폴더에 옮깁니다."
                               Foreground="{StaticResource SpdMutedTextBrush}" TextWrapping="Wrap"/>
                    <CheckBox x:Name="IncludeReviewBox" Content="확인 필요 항목도 함께 적용"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="변경 전 확인" Style="{StaticResource MacToolbarButtonStyle}" Click="PreviewChanges"/>
                        <Button Content="선택 항목 적용" Style="{StaticResource MacToolbarButtonStyle}" Click="ApplyChanges"/>
                        <Button Content="격리 롤백" Style="{StaticResource MacToolbarButtonStyle}" Click="RollbackChanges"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- PCCare 51: macOS depth + One UI reachability + Windows 11 materials. -->
    <SolidColorBrush x:Key="PccCanvasBrush" Color="#F3F6FB"/>
    <SolidColorBrush x:Key="PccSidebarBrush" Color="#E9EEF6"/>
    <SolidColorBrush x:Key="PccSurfaceBrush" Color="#FEFFFF"/>
    <SolidColorBrush x:Key="PccSurfaceMutedBrush" Color="#F7F9FC"/>
    <SolidColorBrush x:Key="PccTextBrush" Color="#17233C"/>
    <SolidColorBrush x:Key="PccTextMutedBrush" Color="#718096"/>
    <SolidColorBrush x:Key="PccBorderBrush" Color="#1A64748B"/>
    <SolidColorBrush x:Key="PccAccentBrush" Color="#2478F2"/>
    <SolidColorBrush x:Key="PccAccentSoftBrush" Color="#EAF3FF"/>
    <SolidColorBrush x:Key="PccHeroTextBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="PccHeroTextMutedBrush" Color="#DCE9FA"/>
    <SolidColorBrush x:Key="PccHeroAccentBrush" Color="#8EC5FF"/>
    <SolidColorBrush x:Key="PccSuccessBrush" Color="#16A36A"/>
    <SolidColorBrush x:Key="PccSuccessSoftBrush" Color="#EAF8F2"/>
    <SolidColorBrush x:Key="PccCautionBrush" Color="#B3730A"/>
    <SolidColorBrush x:Key="PccCautionSoftBrush" Color="#FFF7E7"/>
    <SolidColorBrush x:Key="PccDangerBrush" Color="#D84449"/>
    <SolidColorBrush x:Key="PccDangerSoftBrush" Color="#FFF0F1"/>

    <LinearGradientBrush x:Key="PccHeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#162B4F" Offset="0"/>
        <GradientStop Color="#173E78" Offset="0.58"/>
        <GradientStop Color="#176CD1" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PccPrimaryButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3488F7" Offset="0"/>
        <GradientStop Color="#1D6DDD" Offset="1"/>
    </LinearGradientBrush>

    <Thickness x:Key="PccPagePadding">34,30,38,40</Thickness>
    <Thickness x:Key="PccCardPadding">22</Thickness>
    <CornerRadius x:Key="PccCardCornerRadius">20</CornerRadius>
    <CornerRadius x:Key="PccControlCornerRadius">13</CornerRadius>

    <Style x:Key="PccCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PccSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PccBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource PccCardCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource PccCardPadding}"/>
    </Style>

    <Style x:Key="PccHeroCardStyle" TargetType="Border" BasedOn="{StaticResource PccCardStyle}">
        <Setter Property="Background" Value="{StaticResource PccHeroBrush}"/>
        <Setter Property="BorderBrush" Value="#26558F"/>
        <Setter Property="CornerRadius" Value="24"/>
        <Setter Property="Padding" Value="28"/>
        <Setter Property="MinHeight" Value="150"/>
    </Style>

    <Style x:Key="PccPrimaryButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Padding" Value="18,9"/>
        <Setter Property="CornerRadius" Value="{StaticResource PccControlCornerRadius}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource PccPrimaryButtonBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="PccSecondaryButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="CornerRadius" Value="{StaticResource PccControlCornerRadius}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PccTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource PccSurfaceMutedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PccBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="PccDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PccPrimaryButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PccDangerBrush}"/>
    </Style>

    <Style x:Key="PccPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PccTextBrush}"/>
        <Setter Property="CharacterSpacing" Value="-20"/>
    </Style>

    <Style x:Key="PccSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="21"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PccTextBrush}"/>
    </Style>

    <!-- Compatibility aliases let existing pages adopt the new language incrementally. -->
    <Style x:Key="MacWindowPanelStyle" TargetType="Border" BasedOn="{StaticResource PccCardStyle}"/>
    <Style x:Key="PremiumHeroCardStyle" TargetType="Border" BasedOn="{StaticResource PccHeroCardStyle}"/>
    <Style x:Key="PremiumPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PccPrimaryButtonStyle}"/>
    <Style x:Key="MacToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource PccSecondaryButtonStyle}"/>
    <Style x:Key="MacPageTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource PccPageTitleStyle}"/>
    <Style x:Key="MacSectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource PccSectionTitleStyle}"/>
    <Style x:Key="MacSidebarButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="13,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PccTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style x:Key="MacSearchBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="13,7"/>
        <Setter Property="Foreground" Value="{StaticResource PccTextBrush}"/>
        <Setter Property="Background" Value="#BFFFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource PccBorderBrush}"/>
        <Setter Property="PlaceholderForeground" Value="{StaticResource PccTextMutedBrush}"/>
    </Style>
</ResourceDictionary>

<Page
    x:Class="SmartPerformanceDoctor.App.Views.ReleaseArtifactGatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource SpdMacPagePadding}" Style="{StaticResource MacPageRootStackStyle}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="릴리즈 산출물 게이트" Style="{StaticResource MacPageTitleStyle}"/>
                    <TextBlock Text="포터블·설치 패키지·무결성 검사·서명·업데이트 채널 준비 상태를 최종 점검합니다."
                               Style="{StaticResource MacInlineStatusTextStyle}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="게이트 실행" Style="{StaticResource MacToolbarButtonStyle}" Click="RunGate"/>
            </Grid>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Status}" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Confidence}" Style="{StaticResource MacInlineStatusTextStyle}"/>
                    <TextBlock Text="{Binding Summary}" Style="{StaticResource MacInlineStatusTextStyle}"/>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="1.2*,1.2*" ColumnSpacing="16">
                <Border Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="점검 항목" FontSize="20" FontWeight="SemiBold"/>
                        <ListView ItemsSource="{Binding Gates}" Style="{StaticResource StableLogListViewStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StableLogItemPanelStyle}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource StableLogTitleTextStyle}"/>
                                                <TextBlock Text="{Binding Message}" Style="{StaticResource StableLogPreviewTextStyle}"/>
                                                <TextBlock Text="{Binding Path}" Style="{StaticResource StableLogMetaTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Severity}" Style="{StaticResource StableLogMetaTextStyle}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource MacWindowPanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="배포 산출물" FontSize="20" FontWeight="SemiBold"/>
                        <ListView ItemsSource="{Binding Artifacts}" Style="{StaticResource StableLogListViewStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StableLogItemPanelStyle}">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource StableLogTitleTextStyle}"/>
                                            <TextBlock Text="{Binding Status}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Sha256}" Style="{StaticResource StableLogMetaTextStyle}"/>
                                            <TextBlock Text="{Binding Path}" Style="{StaticResource StableLogMetaTextStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource MacWindowPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="다음 조치" FontSize="20" FontWeight="SemiBold"/>
                    <ItemsControl ItemsSource="{Binding NextActions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="0,0,0,8" Style="{StaticResource MacInlineStatusTextStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="SpdWindowBrush" Color="#F3F6FB"/><SolidColorBrush x:Key="SpdPanelBrush" Color="#FDFEFF"/><SolidColorBrush x:Key="SpdPanelBorderBrush" Color="#E4EAF2"/>
    <SolidColorBrush x:Key="SpdTextBrush" Color="#172033"/><SolidColorBrush x:Key="SpdMutedBrush" Color="#667085"/><SolidColorBrush x:Key="SpdAccentBrush" Color="#0A84FF"/><SolidColorBrush x:Key="SpdAccentSoftBrush" Color="#EAF4FF"/><SolidColorBrush x:Key="SpdSeparatorBrush" Color="#D7DEE8"/><SolidColorBrush x:Key="SpdSidebarMutedBrush" Color="#BED4F7"/>
    <Style x:Key="SpdInstallerStepStyle" TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource SpdSidebarMutedBrush}"/><Setter Property="FontSize" Value="13"/><Setter Property="Margin" Value="0,0,0,17"/><Setter Property="Padding" Value="10,7"/></Style>
    <Style x:Key="SpdPrimaryButtonStyle" TargetType="Button"><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="{StaticResource SpdAccentBrush}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="18,10"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="11" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#0074E8"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Background" Value="#0068D1"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="Root" Property="Opacity" Value="0.42"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="SpdSecondaryButtonStyle" TargetType="Button"><Setter Property="Foreground" Value="{StaticResource SpdTextBrush}"/><Setter Property="Background" Value="#F4F7FB"/><Setter Property="BorderBrush" Value="{StaticResource SpdSeparatorBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="18,10"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="11" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#EAF1FA"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Background" Value="#DEE8F4"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="Root" Property="Opacity" Value="0.42"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="SpdThinProgressStyle" TargetType="ProgressBar"><Setter Property="Foreground" Value="{StaticResource SpdAccentBrush}"/><Setter Property="Background" Value="#E6EDF6"/><Setter Property="BorderThickness" Value="0"/></Style>
    <Style TargetType="CheckBox"><Setter Property="Foreground" Value="{StaticResource SpdTextBrush}"/><Setter Property="FontSize" Value="13"/></Style><Style TargetType="RadioButton"><Setter Property="Foreground" Value="{StaticResource SpdTextBrush}"/><Setter Property="FontSize" Value="13"/></Style><Style TargetType="TextBox"><Setter Property="Foreground" Value="{StaticResource SpdTextBrush}"/><Setter Property="Background" Value="#F8FAFD"/><Setter Property="BorderBrush" Value="{StaticResource SpdSeparatorBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10,8"/></Style>
</ResourceDictionary>